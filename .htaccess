Options -Indexes
Options +FollowSymLinks

# ── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Protect .env.php (never serve it to browsers) ────────────────────────────
<Files ".env.php">
    Require all denied
</Files>
<Files ".env.php.example">
    Require all denied
</Files>

# ── Enable mod_rewrite ────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ── 1. Redirect /TR/ → /tr/ (from vercel.json) ───────────────────────────
    RewriteRule ^TR/(.*)$ /tr/$1 [R=301,L]

    # ── 2. API: route /api/contact (no extension, no trailing slash) → PHP ────
    RewriteRule ^api/contact/?$ /api/contact.php [L]

    # ── 3. Trailing slash enforcement (add slash to extensionless paths) ───────
    # Skip files that actually exist and have an extension
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_URI} !/$
    RewriteCond %{REQUEST_URI} !\.(html|css|js|php|png|jpg|jpeg|gif|webp|svg|ico|woff|woff2|ttf|eot|pdf|zip|txt|xml|map)$ [NC]
    RewriteRule ^(.+)$ /$1/ [R=301,L]

    # ── 4. Clean URLs: serve index.html from a folder ─────────────────────────
    # If the request is for a directory, serve index.html inside it
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^(.*[^/])/?$ /$1/index.html [L]

    # ── 5. Clean URL fallback: /some/path/ → /some/path/index.html ───────────
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
    RewriteRule ^(.+)/$ /$1/index.html [L]

</IfModule>

# ── Gzip / Brotli compression ─────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
    AddOutputFilterByType DEFLATE application/json image/svg+xml text/plain
</IfModule>

# ── Browser caching ───────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html                  "access plus 1 hour"
    ExpiresByType text/css                   "access plus 1 month"
    ExpiresByType application/javascript     "access plus 1 month"
    ExpiresByType image/png                  "access plus 6 months"
    ExpiresByType image/jpeg                 "access plus 6 months"
    ExpiresByType image/webp                 "access plus 6 months"
    ExpiresByType image/svg+xml              "access plus 1 month"
    ExpiresByType font/woff2                 "access plus 1 year"
    ExpiresByType font/woff                  "access plus 1 year"
</IfModule>
