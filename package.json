{
  "name": "myziron-com",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --cache --format stylish",
    "lint:fix": "eslint . --fix --cache --format stylish",
    "lint:full": "eslint . --cache --format compact --max-warnings=9999",
    "lint:file": "eslint --cache --format compact --max-warnings=9999",
    "prettier:check": "prettier --check \"az/**/*.html\" \"en/**/*.html\" \"tr/**/*.html\" \"ru/**/*.html\" index.html",
    "prettier:fix": "prettier --write \"az/**/*.html\" \"en/**/*.html\" \"tr/**/*.html\" \"ru/**/*.html\" index.html",
    "compress": "rm -f myziron-com.zip && zip -rq myziron-com.zip api assets az en ru tr .htaccess index.html $(test -f myziron-katalog.pdf && echo myziron-katalog.pdf || true)"
  },
  "dependencies": {
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "@html-eslint/eslint-plugin": "^0.59.0",
    "@html-eslint/parser": "^0.59.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-compact": "^9.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3"
  }
}
