{
  "cleanUrls": true,
  "trailingSlash": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "redirects": [
    { "source": "/TR/:path*", "destination": "/tr/:path*", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/contact/", "destination": "/api/contact" }
  ]
}
