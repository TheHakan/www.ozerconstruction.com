{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ESLint",
      "type": "shell",
      "command": "npm run lint:full",
      "isBackground": false,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "close": false,
        "revealProblems": "onProblem"
      },
      "problemMatcher": ["$eslint-compact"],
      "group": "build"
    },
    {
      "label": "Prettier",
      "type": "shell",
      "command": "npm run prettier:check",
      "isBackground": false,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "close": false,
        "revealProblems": "onProblem"
      },
      "problemMatcher": [
        {
          "owner": "prettier",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "severity": "warning",
          "pattern": { "regexp": "^\\[warn\\] (\\S+)$", "file": 1 }
        },
        {
          "owner": "prettier",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "severity": "error",
          "pattern": {
            "regexp": "^\\[error\\] (\\S+): (.+)$",
            "file": 1,
            "message": 2
          }
        }
      ],
      "group": "build"
    },
    {
      "label": "Lint: Watch",
      "dependsOn": ["ESLint", "Prettier"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "runOptions": { "runOn": "folderOpen" },
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
