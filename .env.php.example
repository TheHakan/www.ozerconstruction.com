<?php
/**
 * .env.php — local environment variables for SCZ Metal
 *
 * DO NOT commit this file to Git. It is listed in .gitignore.
 * Upload this file directly to the server via FTP/File Manager.
 *
 * Usage: putenv() calls below make variables available via getenv()
 */

putenv('SMTP_HOST=mail.scz.az');
putenv('SMTP_PORT=587');
putenv('SMTP_SECURE=false');          // true = SSL port 465 | false = STARTTLS port 587
putenv('SMTP_USER=info@scz.az');      // your Hostinger email address
putenv('SMTP_PASS=YOUR_PASSWORD_HERE');
